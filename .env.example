# Environment Configuration Template

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/archery
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_TITLE=Archery Scoring System
API_VERSION=0.1.0
API_WORKERS=4

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Storage
STORAGE_PATH=/storage
STORAGE_QUOTA_GB=10

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Image Processing
IMAGE_JPEG_QUALITY=70
IMAGE_RESIZE_WIDTH=1024
IMAGE_RESIZE_HEIGHT=1024
#####
# Development Environment Configuration
# Copy from .env.example and update as needed

ENVIRONMENT=development
API_TITLE=Archery Scoring System API
API_VERSION=1.0.0
API_WORKERS=2
LOG_LEVEL=DEBUG
DEBUG=True

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://archery:archery_pass@localhost:5432/archery_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Cache (Redis via Docker)
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5
CACHE_TTL=60

# Security
JWT_SECRET=dev-secret-jwt-key-change-in-production-ybsecure123
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8
REFRESH_TOKEN_EXPIRATION_DAYS=30
PASSWORD_HASH_ALGORITHM=bcrypt

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://localhost:5173,http://localhost:5174
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Storage
STORAGE_PATH=./storage
STORAGE_QUOTA_GB=10
IMAGE_JPEG_QUALITY=70
IMAGE_MAX_WIDTH=1024
IMAGE_MAX_HEIGHT=1024

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10000
RATE_LIMIT_WINDOW_SECONDS=60
